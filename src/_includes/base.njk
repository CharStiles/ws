<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title and title != site.name %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="icon" href="/assets/favicon-32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/assets/favicon-180.png" sizes="180x180" type="image/png">
  <link rel="apple-touch-icon" href="/assets/favicon-180.png">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <header>
    <nav>
      <a href="/" class="home-link" aria-label="{{ site.name }} — home">⊹</a>
      <a href="/about/">About</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <a href="{{ site.emailList }}">Email list</a>
    <a href="{{ site.instagram }}">Instagram</a>
  </footer>

  <script src="/assets/js/hover-shader.js" defer></script>
</body>
</html>
